# Nginx + Varnish Configuration
# Varnish sẽ cache content từ Nginx

# Nginx port (backend)
NGINX_PORT=8080

# Varnish port (public facing)
VARNISH_PORT=80
VARNISH_ADMIN_PORT=6082

# Varnish cache size
VARNISH_SIZE=512M

# Nginx directories
CONF_DIR=./nginx/conf.d
CERT_DIR=./nginx/certs
PROJECT_DIR=/var/www

# Varnish VCL file
VARNISH_VCL=./varnish/default.vcl
