ARG PHP_VERSION
ARG NODE_VERSION=20
ARG UID=1000
ARG GID=1000
FROM php:${PHP_VERSION}-fpm

ARG NODE_VERSION
ARG UID
ARG GID

# Install system dependencies, dev libs, and dev tools in one layer
RUN apt-get update && apt-get install -y \
    bash-completion \
    cron curl git less nano procps unzip vim wget \
    libfreetype6-dev libicu-dev libjpeg62-turbo-dev libmemcached-dev \
    libpng-dev libssl-dev libxml2-dev libxslt-dev libzip-dev zlib1g-dev \
    --no-install-recommends && \
    rm -rf /var/lib/apt/lists/*

# Install FTP extension
RUN docker-php-ext-configure ftp --with-ftp-ssl \
    && docker-php-ext-install ftp

# GD extension
RUN docker-php-ext-configure gd \
    --with-jpeg \
    --with-freetype && \
    docker-php-ext-install -j$(nproc) gd

# Install intl
RUN docker-php-ext-configure intl && \
    docker-php-ext-install -j$(nproc) intl

# Install other common extensions
RUN docker-php-ext-install -j$(nproc) \
    opcache bcmath pdo_mysql soap xsl zip sockets mysqli

# Install Redis
RUN pecl install redis \
    && docker-php-ext-enable redis

# Install memcached
RUN pecl install memcached \
    && docker-php-ext-enable memcached

# Xdebug installation
RUN pecl install xdebug && docker-php-ext-enable xdebug

# Install Composer
RUN curl -sS https://getcomposer.org/installer | php && \
    mv composer.phar /usr/local/bin/composer

ENV COMPOSER_HOME=/composer \
    PATH="/composer/vendor/bin:${PATH}"

# Install Laravel Installer
RUN composer global require laravel/installer

# Add NodeSource Node.js repo
RUN curl -fsSL https://deb.nodesource.com/setup_${NODE_VERSION}.x | bash -

# Install Node.js (includes npm and npx)
RUN apt-get install -y nodejs

# Install WP-CLI
RUN curl -O https://raw.githubusercontent.com/wp-cli/builds/gh-pages/phar/wp-cli.phar && \
    chmod +x wp-cli.phar && \
    mv wp-cli.phar /usr/local/bin/wp

# Copy custom PHP config
COPY ./php-custom.ini "$PHP_INI_DIR/conf.d/custom.ini"

# Set default php.ini (development config)
RUN cp "$PHP_INI_DIR/php.ini-development" "$PHP_INI_DIR/php.ini"

# Create user and set up /xdebug with proper ownership
RUN groupadd -g ${GID} appuser \
 && useradd -u ${UID} -g appuser -m appuser -s /bin/bash \
 && mkdir -p /xdebug/profiles /xdebug/traces \
 && chown -R appuser:appuser /xdebug

USER appuser
WORKDIR /var/www

EXPOSE 9000

CMD ["php-fpm"]
