# ============================================
# HOMELAB ENVIRONMENT CONFIGURATION
# ============================================

# Project directory (mount to /var/www in containers)
PROJECT_DIR=./projects

# User/Group IDs (match your host user)
UID=1000
GID=1000

# Xdebug configuration
XDEBUG_MODE=off
# Options: off, develop, debug, coverage, profile, trace
# Use 'debug' for step debugging with IDE

XDEBUG_CONFIG=
# Example: client_host=host.docker.internal client_port=9003

# Xdebug output directory
XDEBUG_OUTPUT_DIR=./xdebug-output

# Varnish configuration
VARNISH_SIZE=256M

# Timezone
TZ=UTC
